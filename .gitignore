# ==============================================================================
# 🛡️ 《Qwen3.7-MAX 代码质量总规范》V3.0 - Tauri v2 全栈项目 .gitignore
# 适用架构：前端 (Vue/Vite/Node.js) + 后端 (Rust/Cargo/Tauri)
# ==============================================================================

# ------------------------------------------------------------------------------
# 📦 1. Node.js 与前端构建产物 (Frontend / Vite)
# ------------------------------------------------------------------------------
# 依赖目录（必须忽略，通过 package.json 恢复）
node_modules/

# Vite 构建输出目录
dist/
dist-ssr/
build/

# 本地环境变量文件（包含敏感密钥，绝不提交）
.env.local
.env.*.local
*.local

# 包管理器日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# 🦀 2. Rust 与 Cargo 编译产物 (Backend / Tauri) - 【核心修复区】
# ------------------------------------------------------------------------------
# Rust 编译输出目录（极其庞大，包含 debug/release 二进制文件和中间产物，必须忽略！）
src-tauri/target/

# Rust 崩溃转储文件
*.dmp

# ------------------------------------------------------------------------------
# ⚙️ 3. Tauri v2 特定生成文件 (Tauri Specific)
# ------------------------------------------------------------------------------
# Tauri 自动生成的 API 模式文件（每次编译自动重新生成，无需版本控制）
src-tauri/gen/schemas/

# Tauri 自动生成的图标和启动图缓存（如果使用了 tauri icon 命令）
# src-tauri/icons/  # 注意：如果您自定义了图标，请不要忽略此目录！

# Tauri 打包生成的最终安装包目录（包含在 target 中，但显式声明以防万一）
src-tauri/target/release/bundle/

# ------------------------------------------------------------------------------
# 📝 4. 项目特定测试与临时文件 (Project Specific)
# ------------------------------------------------------------------------------
# 拦截测试脚本生成的临时日志文件（如 greet_log.txt）
greet_log.txt
*.tmp
*.bak

# ------------------------------------------------------------------------------
# 💻 5. 操作系统与编辑器临时文件 (OS & Editor)
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# IDE 与编辑器配置（仅保留必要的共享配置）
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml
*.ipr
*.iws